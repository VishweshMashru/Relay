# Copy to .env and fill in.

# Postgres direct endpoint (drop -pooler from Neon so LISTEN/NOTIFY works).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudflare Stream Live. Account ID is in the CF dashboard right sidebar; API
# token needs Stream:Edit permission on the account.
ACCOUNT_ID=your-cf-account-id
API_TOKEN=your-cf-api-token

# Optional
RELAY_API_ADDR=:8080
