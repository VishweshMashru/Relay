# Copy to .env and fill in.

# Postgres direct endpoint (drop -pooler from Neon so LISTEN/NOTIFY works).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Cloudflare Stream Live. Account ID is in the CF dashboard right sidebar;
# API token needs Stream:Edit permission on the account.
ACCOUNT_ID="your-cf-account-id"
API_TOKEN="your-cf-api-token"

# HMAC secret for signing edge JWTs. Generate: openssl rand -hex 32.
# Rotating this invalidates every issued edge token — re-run `relay-admin
# edge create` to issue fresh ones.
RELAY_JWT_SECRET="at-least-16-chars-recommend-32-bytes-hex"

# Optional
RELAY_API_ADDR=:8080
