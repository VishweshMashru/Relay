# Caddy is doing three things:
#   1. terminating TLS via Let's Encrypt (auto-cert, auto-renew)
#   2. reverse-proxying to relay-api on the internal Docker network
#   3. gzipping responses
#
# The site's hostname is templated from RELAY_DOMAIN in .env.
# For local testing without a domain, replace {$RELAY_DOMAIN} with ":80" and
# it will serve HTTP on port 80.

{$RELAY_DOMAIN} {
    encode gzip zstd

    # Health probe: no logs, no auth.
    handle /v1/health {
        reverse_proxy relay-api:8080
    }

    # Self-hosted media plane (RELAY_STREAM_PROVIDER=selfhosted): HLS and
    # WHIP/WHEP ride the same domain; MediaMTX serves them internally.
    handle_path /hls/* {
        reverse_proxy mediamtx:8888
    }
    handle_path /webrtc/* {
        reverse_proxy mediamtx:8889
    }

    # Everything else: log + proxy.
    handle {
        reverse_proxy relay-api:8080 {
            # Long-poll: server holds the response for ~25s. Bump the read
            # timeout so Caddy doesn't cut the client off.
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    log {
        output stdout
        format console
    }
}
