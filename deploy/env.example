# Copy to `.env` at the repo root on your VPS (docker-compose reads from there).

# Domain that points at this VPS. Caddy auto-provisions a TLS cert from
# Let's Encrypt on first startup. Set a plain hostname (no https://).
RELAY_DOMAIN=api.your-domain.com

# Postgres direct endpoint (drop -pooler from Neon so LISTEN/NOTIFY works).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudflare Stream Live.
ACCOUNT_ID=your-cf-account-id
API_TOKEN=your-cf-api-token

# Generate both: openssl rand -hex 32
RELAY_JWT_SECRET=64-hex-chars
RELAY_ADMIN_TOKEN=64-hex-chars

# Blob storage for the assets (VOD) domain — any S3-compatible bucket.
# Optional: leave unset and asset endpoints return 501, everything else works.
# For Cloudflare R2: endpoint is https://<account_id>.r2.cloudflarestorage.com
# and region stays "auto".
#RELAY_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#RELAY_S3_REGION=auto
#RELAY_S3_BUCKET=relay-assets
#RELAY_S3_ACCESS_KEY_ID=...
#RELAY_S3_SECRET_ACCESS_KEY=...
